{
  "name": "sotto",
  "version": "1.4.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edycutjong/sotto.git"
  },
  "bugs": {
    "url": "https://github.com/edycutjong/sotto/issues"
  },
  "homepage": "https://sotto.edycu.dev",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "audit": "npm audit --audit-level=high",
    "ci": "(npm run audit || true) && npm run lint && npm run typecheck && npm run test:coverage",
    "ci:full": "npm run ci && npm run build && npm run e2e",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "lighthouse": "npx lhci autorun",
    "prove:demo": "node scripts/prove-and-verify.mjs",
    "prove:demo:reserve": "node scripts/prove-and-verify-reserve.mjs"
  },
  "dependencies": {
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^16.0.0",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@lhci/cli": "^0.13.0",
    "@playwright/test": "^1.42.1",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
